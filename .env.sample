# Whisper (Wyoming STT)
WHISPER_HOST=
WHISPER_PORT=10300

# Home Assistant (TTS via Piper + DLNA)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
HA_MEDIA_PLAYER=media_player.your_device
HA_TTS_ENTITY=tts.piper

# Wake word
WAKEWORD_MODEL=/path/to/your_wakeword.onnx
WAKEWORD_THRESHOLD=0.5

# Silence detection
SILENCE_RMS=500
SILENCE_SECS=1.5
